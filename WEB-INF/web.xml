<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="3.1">

    <!-- ADD TASK -->
    <servlet>
        <servlet-name>AddTask</servlet-name>
        <servlet-class>AddTaskServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddTask</servlet-name>
        <url-pattern>/addTask</url-pattern>
    </servlet-mapping>

    <!-- COMPLETE TASK -->
    <servlet>
        <servlet-name>CompleteTask</servlet-name>
        <servlet-class>CompleteTaskServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CompleteTask</servlet-name>
        <url-pattern>/complete</url-pattern>
    </servlet-mapping>

    <!-- DELETE TASK -->
    <servlet>
        <servlet-name>DeleteTask</servlet-name>
        <servlet-class>DeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteTask</servlet-name>
        <url-pattern>/delete</url-pattern>
    </servlet-mapping>

    <!-- SKIP DAY -->
    <servlet>
        <servlet-name>SkipDay</servlet-name>
        <servlet-class>SkipDayServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SkipDay</servlet-name>
        <url-pattern>/skipDay</url-pattern>
    </servlet-mapping>

    <!-- LOGIN -->
    <servlet>
        <servlet-name>Login</servlet-name>
        <servlet-class>LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- REGISTER -->
    <servlet>
        <servlet-name>Register</servlet-name>
        <servlet-class>RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Register</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- LOGOUT -->
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- UPDATE PROFILE -->
    <servlet>
        <servlet-name>UpdateProfile</servlet-name>
        <servlet-class>UpdateProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProfile</servlet-name>
        <url-pattern>/updateProfile</url-pattern>
    </servlet-mapping>

    <!-- ADD CATEGORY -->
    <servlet>
        <servlet-name>AddCategory</servlet-name>
        <servlet-class>AddCategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddCategory</servlet-name>
        <url-pattern>/addCategory</url-pattern>
    </servlet-mapping>

    <!-- DELETE CATEGORY -->
    <servlet>
        <servlet-name>DeleteCategory</servlet-name>
        <servlet-class>DeleteCategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteCategory</servlet-name>
        <url-pattern>/deleteCategory</url-pattern>
    </servlet-mapping>

    <!-- EDIT CATEGORY -->
    <servlet>
        <servlet-name>EditCategory</servlet-name>
        <servlet-class>EditCategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditCategory</servlet-name>
        <url-pattern>/editCategory</url-pattern>
    </servlet-mapping>

</web-app>